{% extends 'base.html.twig' %}

{% block title %}WChat{% endblock %}
{% block stylesheets %}
    {{ encore_entry_link_tags('chat') }}
{% endblock %}
{% block javascripts %}
    {{ encore_entry_script_tags('chat') }}
{% endblock %}
{% block body %}
    <div class="container">
        <div class="available_chats">
            <div class="title">Available chats</div>
            <div class="chats">
                {% for chat in chats %}
                    {% if chat != null %}
                    <form action="{{ path("app_chat_switch") }}" method="post">
                        <div class="chat">
                            <input type="submit" value="" class="chat_button">
                            <input type="text" name="_chat_id" hidden value="{{ chat.id }}">
                            <div class="icon">
                                <img src="{{ chat.image }}" alt="">
                            </div>
                            <div class="text">
                                <div class="title">{{chat.name}}</div>
                                {% if chat.lastMessage != null %}
                                    <div class="last_message">{{chat.lastMessage.user.username}}: {{chat.lastMessage.message}}</div>
                                {% endif %}
                            </div>
                            {% for notification in user_notification %}
                                {% if notification.chat == chat and notification.notifications != 0 %}
                                    <div class="notif">+ {{notification.notifications}}</div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </form>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        {% if current_chat != null %}
            <div class="chat_m">
                <div class="chat_header">
                    <div class="title">{{current_chat.name}}</div>
                    {% if user_info.getRoleId() >= 2 %}
                        <div class="settings">
                            <img src="/icons/settings.svg" alt="">
                        </div>
                    {% endif %}
                    <div class="files">
                        <img src="/icons/b_folder.svg" alt="">
                    </div>
                </div>
                <div class="messages">
                    {% for message in chat_messages %}
                        {% if message.user == app.user %}
                            <div class="your_message">
                                <div class="icon">
                                    <img src="" alt="">
                                </div>
                                <div class="mess_cont">
                                    <div class="name">{{message.user.username}}</div>
                                    <div class="mess">{{message.message}}</div>
                                </div>
                                <div class="data">{{message.date}}</div>
                            </div>
                        {% else %}
                            <div class="message">
                                <div class="icon">
                                    <img src="" alt="">
                                </div>
                                <div class="mess_cont">
                                    <div class="name">{{message.user.username}}</div>
                                    <div class="mess">{{message.message}}</div>
                                </div>
                                <div class="data">{{message.date}}</div>
                            </div> 
                        {% endif %}
                    {% endfor %}
                </div>
                <div class="post_message">
                    <form action="{{ path("app_chat_send_message" )}}" method="post">
                        <div class="post_container">
                            <div class="add_image">
                                <img src="/icons/add_icon.svg" alt="">
                            </div>
                            <input type="text" required name="_message" placeholder="Your message" id="text">
                            <input type="submit" value="Send" class="post_button">
                        </div>
                    </form>
                </div>
            </div>
            <div class="f_files">
                <div class="title">Files</div>
                <div class="folders">
                    <div class="folder">
                        <div class="f_title">
                            <div class="name">{{current_chat.name}}</div>
                            <img src="/icons/bottom_.svg" alt="">
                            <div class="c_files">5 files</div>
                        </div>
                    </div>
                    <div class="f_files">
                        {% for file in chat_files %}
                            <div class="file">
                                <div class="name">{{file.name}}</div>
                                <div class="download">Download</div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% if user_info.getRoleId() >= 1 %}
                    <div class="buttons">
                        <div class="add_folder">Add folder</div>
                        <div class="add_file">Add file</div>
                        <div class="delete_folder">Delete folder</div>
                        <div class="delete_file">Delete file</div>
                    </div>
                {% endif %}
            </div>
            {% if user_info.getRoleId() >= 2%}
                <div class="f_settings">
                    <div class="title">Chat Settings</div>
                    {% if user_info.getRoleId() >= 3 %}
                        <form action="{{ path('app_chat_settings_change_photo') }}" method="post" enctype="multipart/form-data">
                            <label for="chat_photo">Chat photo: </label>
                            <input required type="file" name="image" id="chat_photo" accept="image/*">
                            <input type="submit" value="Change chat photo">
                        </form>                  
                        <form action="{{ path('app_chat_settings_change_name') }}" method="post" class="change_group_name_form">
                            <label for="group_name">Group name: </label>
                            <input type="text" required id="group_name" name="group_name" placeholder="{{current_chat.name}}">
                            <input type="submit" value="Change group name">
                        </form>
                        <form action="{{ path('app_chat_settings_change_role') }}" method="post" class="change_member_role">
                            <label style="flex-basis: 90%;" for="member_role">Change member role: </label>
                            <label for="user">User email: </label>
                            <input type="text" required id="user" name="user" placeholder="User email">
                            <label for="member_role">Role: </label>
                            <input type="number" min="0" max="3" required id="member_role" name="member_role" placeholder="Role (0-3)">
                            <input type="submit" value="Change role">
                        </form>
                    {% endif %}
                    <form action="{{ path('app_chat_settings_add_member') }}" method="post" class="add_new_member_form">
                        <label for="add_member">Add a new member: </label>
                        <input type="text" required id="add_member" name="add_member" placeholder="User name or email">
                        <input type="submit" value="Add new member">
                    </form>
                    <form action="{{ path('app_chat_settings_remove_member') }}" method="post" class="delete_member_form">
                        <label for="delete_member">Delete member: </label>
                        <input required type="text" id="delete_member" name="delete_member" placeholder="User name or email">
                        <input type="submit" value="Kick member">
                    </form>
                </div>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}
